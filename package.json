{
  "name": "nunjitsu",
  "version": "0.3.1",
  "description": "A secure direct string template engine written in TypeScript",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rugvip/nunjitsu.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "benchmark": "node benchmarks/run.ts",
    "benchmark:quick": "node benchmarks/run.ts --warmup=1 --iterations=3 --loops=1",
    "build": "tsdown",
    "changeset": "changeset",
    "prepack": "pnpm run build",
    "release:check": "node scripts/release/verifyReleaseVersion.mjs",
    "test": "pnpm run typecheck && pnpm run test:source && pnpm run test:benchmark && pnpm run test:package",
    "test:benchmark": "node benchmarks/run.ts --warmup=0 --iterations=1 --loops=1 --silent",
    "test:package": "pnpm run build && node --test tests/package/*.test.*",
    "test:source": "node --test tests/source/*.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "version:packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.13.14",
    "@types/nunjucks": "3.2.6",
    "nunjucks": "3.2.4",
    "tsdown": "^0.22.3",
    "typescript": "~6.0.3"
  }
}
