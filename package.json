{
  "name": "nunjitsu",
  "version": "0.1.0",
  "description": "A secure direct string template engine written in TypeScript",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/legacy/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/esm/index.d.mts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      },
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "benchmark": "node benchmarks/run.ts",
    "benchmark:quick": "node benchmarks/run.ts --warmup=1 --iterations=3 --loops=1",
    "build": "node scripts/build.mjs",
    "clean": "node scripts/clean.mjs",
    "test": "pnpm run typecheck && pnpm run test:source && pnpm run test:benchmark && pnpm run test:package",
    "test:benchmark": "node benchmarks/run.ts --warmup=0 --iterations=1 --loops=1 --silent",
    "test:package": "pnpm run build && pnpm run test:package:types && node --test tests/package/esm.test.mjs tests/package/commonjs.test.cjs",
    "test:package:types": "node scripts/test-package-types.mjs",
    "test:source": "node --test tests/source/*.test.ts",
    "typecheck": "tsgo -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/nunjucks": "3.2.6",
    "@typescript/native-preview": "7.0.0-dev.20260613.1",
    "esbuild": "^0.25.0",
    "nunjucks": "3.2.4",
    "typescript": "~5.7.0"
  }
}
