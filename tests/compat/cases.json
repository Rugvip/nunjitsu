{
  "schemaVersion": 1,
  "cases": [
    {
      "id": "compiler-static-text",
      "template": "Hello world",
      "context": {},
      "autoescape": false,
      "expected": "Hello world"
    },
    {
      "id": "compiler-interpolation",
      "template": "Hello world, {{ name }}",
      "context": { "name": "James" },
      "autoescape": false,
      "expected": "Hello world, James"
    },
    {
      "id": "compiler-adjacent-interpolation",
      "template": "Hello world, {{name}}{{suffix}}, how are you",
      "context": { "name": "James", "suffix": " Long" },
      "autoescape": false,
      "expected": "Hello world, James Long, how are you"
    },
    {
      "id": "compiler-dotted-reference",
      "template": "{{ foo.bar }}",
      "context": { "foo": { "bar": "baz" } },
      "autoescape": false,
      "expected": "baz"
    },
    {
      "id": "compiler-bracket-reference",
      "template": "{{ foo[\"bar\"] }}",
      "context": { "foo": { "bar": "baz" } },
      "autoescape": false,
      "expected": "baz"
    },
    {
      "id": "compiler-missing-root-value",
      "template": "{{ foo }}",
      "context": {},
      "autoescape": false,
      "expected": ""
    },
    {
      "id": "compiler-missing-dotted-value",
      "template": "{{ foo.bar }}",
      "context": {},
      "autoescape": false,
      "expected": ""
    },
    {
      "id": "compiler-missing-value",
      "template": "{{ foo.bar.baz }}",
      "context": {},
      "autoescape": false,
      "expected": ""
    },
    {
      "id": "compiler-missing-mixed-reference",
      "template": "{{ foo.bar.baz[\"biz\"].mumble }}",
      "context": {},
      "autoescape": false,
      "expected": ""
    },
    {
      "id": "compiler-autoescape",
      "template": "{{ foo }}",
      "context": { "foo": "\"'<>&" },
      "autoescape": true,
      "expected": "&quot;&#39;&lt;&gt;&amp;"
    },
    {
      "id": "compiler-explicit-safe-value",
      "template": "{{ foo }}",
      "context": {
        "foo": { "$nunjitsu": "safe", "value": "\"'<>&" }
      },
      "autoescape": true,
      "expected": "\"'<>&"
    },
    {
      "id": "compiler-dynamic-include-context",
      "template": "hello world {% include tmpl %}",
      "templates": { "include.njk": "FooInclude {{ name }}" },
      "nativeRender": false,
      "context": { "name": "thedude", "tmpl": "include.njk" },
      "autoescape": false,
      "expected": "hello world FooInclude thedude"
    },
    {
      "id": "compiler-dynamic-include-set",
      "template": "hello world {% set tmpl = \"include.njk\" %}{% include tmpl %}",
      "templates": { "include.njk": "FooInclude {{ name }}" },
      "nativeRender": false,
      "context": { "name": "thedude" },
      "autoescape": false,
      "expected": "hello world FooInclude thedude"
    },
    {
      "id": "compiler-dynamic-include-attribute",
      "template": "hello world {% include data.tmpl %}",
      "templates": { "include.njk": "FooInclude {{ name }}" },
      "nativeRender": false,
      "context": { "name": "thedude", "data": { "tmpl": "include.njk" } },
      "autoescape": false,
      "expected": "hello world FooInclude thedude"
    },
    {
      "id": "compiler-basic-arithmetic",
      "template": "{{ 3 + 4 - 5 * 6 / 10 }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "4"
    },
    {
      "id": "compiler-exponentiation",
      "template": "{{ 4**5 }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "1024"
    },
    {
      "id": "compiler-floor-division",
      "template": "{{ 9//5 }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "1"
    },
    {
      "id": "compiler-modulus",
      "template": "{{ 9%5 }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "4"
    },
    {
      "id": "compiler-numeric-negation",
      "template": "{{ -5 }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "-5"
    },
    {
      "id": "compiler-string-concatenation",
      "template": "{{ 4 ~ 'hello' }}|{{ 4 ~ 5 }}|{{ 'a' ~ 'b' ~ 5 }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "4hello|45|ab5"
    },
    {
      "id": "compiler-ignore-missing-include",
      "template": "hello world {% include \"missing.njk\" ignore missing %}",
      "templates": {},
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "hello world "
    },
    {
      "id": "compiler-ignore-missing-include-context",
      "template": "hello world {% include \"missing.njk\" ignore missing %}",
      "templates": {},
      "nativeRender": false,
      "context": { "name": "thedude" },
      "autoescape": false,
      "expected": "hello world "
    },
    {
      "id": "compiler-ternary-false",
      "template": "{{ \"foo\" if bar else \"baz\" }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "baz"
    },
    {
      "id": "compiler-ternary-true",
      "template": "{{ \"foo\" if bar else \"baz\" }}",
      "nativeRender": false,
      "context": { "bar": true },
      "autoescape": false,
      "expected": "foo"
    },
    {
      "id": "compiler-inline-if-true",
      "template": "Give me some {{ \"pizza\" if hungry else \"water\" }}",
      "nativeRender": false,
      "context": { "hungry": true },
      "autoescape": false,
      "expected": "Give me some pizza"
    },
    {
      "id": "compiler-inline-if-false",
      "template": "Give me some {{ \"pizza\" if hungry else \"water\" }}",
      "nativeRender": false,
      "context": { "hungry": false },
      "autoescape": false,
      "expected": "Give me some water"
    },
    {
      "id": "compiler-inline-if-not",
      "template": "{{ \"good\" if not hungry }}",
      "nativeRender": false,
      "context": { "hungry": false },
      "autoescape": false,
      "expected": "good"
    },
    {
      "id": "compiler-inline-if-and",
      "template": "{{ \"good\" if hungry and like_pizza }}",
      "nativeRender": false,
      "context": { "hungry": true, "like_pizza": true },
      "autoescape": false,
      "expected": "good"
    },
    {
      "id": "compiler-inline-if-or",
      "template": "{{ \"good\" if hungry or like_pizza }}",
      "nativeRender": false,
      "context": { "hungry": false, "like_pizza": true },
      "autoescape": false,
      "expected": "good"
    },
    {
      "id": "compiler-inline-if-group",
      "template": "{{ \"good\" if (hungry or like_pizza) and anchovies }}",
      "nativeRender": false,
      "context": { "hungry": false, "like_pizza": true, "anchovies": true },
      "autoescape": false,
      "expected": "good"
    },
    {
      "id": "compiler-inline-if-comparison",
      "template": "{{ \"pizza\" if food == \"pizza\" }}{{ \"beer\" if food == \"beer\" }}",
      "nativeRender": false,
      "context": { "food": "beer" },
      "autoescape": false,
      "expected": "beer"
    },
    {
      "id": "compiler-python-style-ternary-tests",
      "template": "{{ \"yes\" if 1 is odd else \"no\" }}|{{ \"yes\" if 2 is even else \"no\" }}|{{ \"yes\" if 2 is odd else \"no\" }}|{{ \"yes\" if 1 is even else \"no\" }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "yes|yes|no|no"
    },
    {
      "id": "compiler-three-value-loop-destructuring",
      "template": "{% for a, b, c in arr %}{{ a }},{{ b }},{{ c }}.{% endfor %}",
      "nativeRender": false,
      "context": { "arr": [["x", "y", "z"], ["1", "2", "3"]] },
      "autoescape": false,
      "expected": "x,y,z.1,2,3."
    },
    {
      "id": "compiler-four-value-loop-destructuring",
      "template": "{% for a, b, c, d in arr %}[{{ a }},{{ b }},{{ c }},{{ d }}]{% endfor %}",
      "nativeRender": false,
      "context": { "arr": [[1, 2, 3, 4], [5, 6, 7, 8]] },
      "autoescape": false,
      "expected": "[1,2,3,4][5,6,7,8]"
    },
    {
      "id": "compiler-set-multiple-and-arithmetic",
      "template": "{% set username = \"foo\" %}{{ username }}|{% set x, y = \"foo\" %}{{ x }}{{ y }}|{% set sum = 1 + 2 %}{{ sum }}",
      "nativeRender": false,
      "context": { "username": "james" },
      "autoescape": false,
      "expected": "foo|foofoo|3"
    },
    {
      "id": "compiler-set-loop-local",
      "template": "{% for i in [1] %}{% set foo=1 %}{% endfor %}{{ foo }}",
      "nativeRender": false,
      "context": { "foo": 2 },
      "autoescape": false,
      "expected": "2"
    },
    {
      "id": "compiler-set-include-isolation",
      "template": "{% include \"set.njk\" %}{{ foo }}",
      "templates": { "set.njk": "{% set foo = \"mumble\" %}" },
      "nativeRender": false,
      "context": { "foo": "bar" },
      "autoescape": false,
      "expected": "bar"
    },
    {
      "id": "compiler-set-context-expression",
      "template": "{% set username = username + \"pasta\" %}{{ username }}",
      "nativeRender": false,
      "context": { "username": "basta" },
      "autoescape": false,
      "expected": "bastapasta"
    },
    {
      "id": "compiler-set-new-loop-local",
      "template": "{% for i in [1] %}{% set val=5 %}{% endfor %}{{ val }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": ""
    },
    {
      "id": "compiler-set-loop-local-accumulation",
      "template": "{% for i in [1,2,3] %}{% if not val %}{% set val=5 %}{% endif %}{% set val=val+1 %}{{ val }}{% endfor %}afterwards: {{ val }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "678afterwards: "
    },
    {
      "id": "compiler-set-resolves-outer-scope",
      "template": "{% set val=1 %}{% for i in [1] %}{% set val=5 %}{% endfor %}{{ val }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "5"
    },
    {
      "id": "compiler-set-outer-accumulation",
      "template": "{% set val=5 %}{% for i in [1,2,3] %}{% set val=val+1 %}{{ val }}{% endfor %}afterwards: {{ val }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "678afterwards: 8"
    },
    {
      "id": "compiler-set-frame-reference",
      "template": "{% set username = user.name %}{{ username }}",
      "nativeRender": false,
      "context": { "user": { "name": "james" } },
      "autoescape": false,
      "expected": "james"
    },
    {
      "id": "compiler-set-same-variable-branches",
      "template": "{% set x = \"hello\" %}{% if false %}{% set x = \"world\" %}{% endif %}{{ x }}|{% set x = \"blue\" %}{% if true %}{% set x = \"green\" %}{% endif %}{{ x }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "hello|green"
    },
    {
      "id": "compiler-block-set-empty-and-text",
      "template": "{% set empty %}{% endset %}[{{ empty }}]|{% set content %}test string{% endset %}{{ content }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "[]|test string"
    },
    {
      "id": "compiler-block-set-loop-include",
      "template": "{% set content %}{% for item in [1, 2, 3] %}{% include \"item.njk\" %} {% endfor %}{% endset %}{{ content }}",
      "templates": { "item.njk": "showing {{ item }}" },
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "showing 1 showing 2 showing 3 "
    },
    {
      "id": "compiler-block-set-nested",
      "template": "{% set outer %}{% set inner %}{% for i in [1, 2, 3] %}item {{ i }} {% endfor %}{% endset %}{% for i in [1, 2, 3] %}inner {{i}}: \"{{ inner }}\" {% endfor %}{% endset %}{{ outer | safe }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "inner 1: \"item 1 item 2 item 3 \" inner 2: \"item 1 item 2 item 3 \" inner 3: \"item 1 item 2 item 3 \" "
    },
    {
      "id": "compiler-block-set-multiple-targets",
      "template": "{% set x,y,z %}cool{% endset %}{{ x }} {{ y }} {{ z }}",
      "nativeRender": false,
      "context": {},
      "autoescape": false,
      "expected": "cool cool cool"
    }
  ]
}
