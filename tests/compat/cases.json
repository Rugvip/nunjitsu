{
  "schemaVersion": 1,
  "cases": [
    {
      "id": "compiler-static-text",
      "template": "Hello world",
      "context": {},
      "autoescape": false,
      "expected": "Hello world"
    },
    {
      "id": "compiler-interpolation",
      "template": "Hello world, {{ name }}",
      "context": { "name": "James" },
      "autoescape": false,
      "expected": "Hello world, James"
    },
    {
      "id": "compiler-adjacent-interpolation",
      "template": "Hello world, {{name}}{{suffix}}, how are you",
      "context": { "name": "James", "suffix": " Long" },
      "autoescape": false,
      "expected": "Hello world, James Long, how are you"
    },
    {
      "id": "compiler-dotted-reference",
      "template": "{{ foo.bar }}",
      "context": { "foo": { "bar": "baz" } },
      "autoescape": false,
      "expected": "baz"
    },
    {
      "id": "compiler-bracket-reference",
      "template": "{{ foo[\"bar\"] }}",
      "context": { "foo": { "bar": "baz" } },
      "autoescape": false,
      "expected": "baz"
    },
    {
      "id": "compiler-missing-root-value",
      "template": "{{ foo }}",
      "context": {},
      "autoescape": false,
      "expected": ""
    },
    {
      "id": "compiler-missing-dotted-value",
      "template": "{{ foo.bar }}",
      "context": {},
      "autoescape": false,
      "expected": ""
    },
    {
      "id": "compiler-missing-value",
      "template": "{{ foo.bar.baz }}",
      "context": {},
      "autoescape": false,
      "expected": ""
    },
    {
      "id": "compiler-missing-mixed-reference",
      "template": "{{ foo.bar.baz[\"biz\"].mumble }}",
      "context": {},
      "autoescape": false,
      "expected": ""
    },
    {
      "id": "compiler-autoescape",
      "template": "{{ foo }}",
      "context": { "foo": "\"'<>&" },
      "autoescape": true,
      "expected": "&quot;&#39;&lt;&gt;&amp;"
    },
    {
      "id": "compiler-explicit-safe-value",
      "template": "{{ foo }}",
      "context": {
        "foo": { "$nunjitsu": "safe", "value": "\"'<>&" }
      },
      "autoescape": true,
      "expected": "\"'<>&"
    },
    {
      "id": "compiler-autoescape-default",
      "template": "{{ foo }}",
      "nativeRender": false,
      "context": { "foo": "\"'<>&" },
      "expected": "&quot;&#39;&lt;&gt;&amp;"
    },
    {
      "id": "compiler-autoescape-reverse",
      "template": "{{ foo|reverse }}",
      "nativeRender": false,
      "context": { "foo": "\"'<>&" },
      "autoescape": true,
      "expected": "&amp;&gt;&lt;&#39;&quot;"
    },
    {
      "id": "compiler-autoescape-reverse-safe",
      "template": "{{ foo|reverse|safe }}",
      "nativeRender": false,
      "context": { "foo": "\"'<>&" },
      "autoescape": true,
      "expected": "&><'\""
    },
    {
      "id": "compiler-autoescape-null",
      "template": "{{ foo }}",
      "context": { "foo": null },
      "autoescape": true,
      "expected": ""
    },
