      "expected": "baz"
    },
    {
      "id": "compiler-ternary-true",
      "template": "{{ \"foo\" if bar else \"baz\" }}",
      "nativeRender": false,
      "context": { "bar": true },
      "autoescape": false,
      "expected": "foo"
    },
    {
      "id": "compiler-inline-if-true",
      "template": "Give me some {{ \"pizza\" if hungry else \"water\" }}",
      "nativeRender": false,
      "context": { "hungry": true },
      "autoescape": false,
      "expected": "Give me some pizza"
    },
    {
      "id": "compiler-inline-if-false",
      "template": "Give me some {{ \"pizza\" if hungry else \"water\" }}",
      "nativeRender": false,
      "context": { "hungry": false },
      "autoescape": false,
      "expected": "Give me some water"
    },
    {
      "id": "compiler-inline-if-not",
