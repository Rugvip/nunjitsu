      "id": "compiler-autoescape-safe-array",
      "template": "{{ foo | safe }}",
      "nativeRender": false,
      "context": { "foo": ["<p>foo</p>"] },
      "autoescape": true,
      "expected": "<p>foo</p>"
    },
    {
      "id": "compiler-safe-filter",
      "template": "{{ foo|safe }}",
